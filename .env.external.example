# External Services Configuration
# Use this when LiteLLM, Ollama, and n8n are running on separate machines
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE (Local to Agent Service VPS)
# =============================================================================
# PostgreSQL running in Docker on the same VPS as agent-service
MARKETPLACE_DB_USER=marketplace
MARKETPLACE_DB_PASSWORD=changeme-strong-password-here
MARKETPLACE_DB_NAME=marketplace

# Full database URL (auto-built from above, or override)
MARKETPLACE_DATABASE_URL=postgresql+asyncpg://marketplace:changeme-strong-password-here@postgres:5432/marketplace

# =============================================================================
# LITELLM GATEWAY (External - via Tailscale)
# =============================================================================
# The Tailscale IP or hostname of your LiteLLM instance
# Example: http://100.x.x.x:4000 (Tailscale IP)
# Example: http://litellm-machine:4000 (Tailscale MagicDNS)
MARKETPLACE_LITELLM_URL=http://100.x.x.x:4000

# API key for LiteLLM authentication
# Get this from your LiteLLM configuration (master_key or generated key)
MARKETPLACE_LITELLM_API_KEY=sk-litellm-your-key-here

# =============================================================================
# AGENT SERVICE API KEY (For n8n Authentication)
# =============================================================================
# Strong random key for n8n to authenticate with agent service
# Generate with: openssl rand -hex 32
MARKETPLACE_API_KEY=your-secure-api-key-here

# =============================================================================
# EXTERNAL APIs
# =============================================================================
# Apify API token for eBay scraping
MARKETPLACE_APIFY_API_TOKEN=your-apify-token-here

# =============================================================================
# N8N CONFIGURATION (Set these in n8n UI or n8n environment)
# =============================================================================
# These are used by n8n, not by the agent service directly
# Set them in your n8n instance:
#
# AGENT_SERVICE_URL=http://localhost:8000
# AGENT_API_KEY=your-secure-api-key-here  (same as MARKETPLACE_API_KEY above)
#
# Note: Use 'localhost' because n8n runs on the same VPS as agent-service
# and agent-service binds to 0.0.0.0:8000

# =============================================================================
# OPTIONAL: LITELLM MODEL CONFIGURATION
# =============================================================================
# Only change these if your LiteLLM has different model names configured
# MARKETPLACE_VISION_MODEL=openai/gpt-4o
# MARKETPLACE_REASONING_MODEL=openai/gpt-4o
# MARKETPLACE_DRAFTING_MODEL=ollama/llama3
